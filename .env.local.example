# --- Supabase Postgres ---
# Pooled connection (pgbouncer, port 6543) used by the app at runtime:
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by Prisma Migrate:
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (optional — button stays disabled until both are set) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Upstash rate limiting (optional — auth rate-limit is a no-op without these) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- AI (open models, OpenAI-compatible) ---
# AI features (goal decomposer, journal insights) degrade to 503 until AI_API_KEY is set.
# Default provider is Groq (open Llama, fast, free tier): https://console.groq.com/keys
AI_API_KEY=""
# Optional overrides (default = Groq + llama-3.1-8b-instant):
# AI_BASE_URL="https://api.groq.com/openai/v1"   # or Together/OpenRouter, or http://localhost:11434/v1 for Ollama
# AI_MODEL="llama-3.1-8b-instant"
