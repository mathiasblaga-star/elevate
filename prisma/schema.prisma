// Elevate — Prisma schema (Supabase Postgres)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
}

enum Category {
  HEALTH
  MINDSET
  PRODUCTIVITY
  SOCIAL
  FINANCE
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum Frequency {
  DAILY
  WEEKLY
}

enum NotifType {
  STREAK
  SYSTEM
  REMINDER
}

enum PartnerStatus {
  PENDING
  ACCEPTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  avatar       String? // hex colour for avatar initial
  plan         Plan     @default(FREE)
  emailDigest  Boolean  @default(false)
  createdAt    DateTime @default(now())

  // gamification
  xp                 Int @default(0)
  level              Int @default(1)
  streakFreezeTokens Int @default(0)

  // personalisation
  theme            String @default("oled") // oled | dark
  accent           String @default("#ffffff")
  lifeScoreWeights Json? // { habits, goals, mood, journal } — fractions summing to 1

  goals         Goal[]
  habits        Habit[]
  habitEntries  HabitEntry[]
  journal       JournalEntry[]
  moods         MoodLog[]
  notifications Notification[]
  routines      HabitRoutine[]
  badges        UserBadge[]
  milestones    GoalMilestone[]
  pomodoros     PomodoroSession[]
  partnerships  Partnership[]     @relation("requester")
}

model Goal {
  id         String     @id @default(cuid())
  userId     String
  title      String
  category   Category   @default(PRODUCTIVITY)
  targetDate DateTime?
  status     GoalStatus @default(NOT_STARTED)
  progress   Int        @default(0) // 0-100
  order      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt @default(now())

  // priority matrix + templates
  urgency    Int? // 0/1 quadrant axis
  importance Int? // 0/1 quadrant axis
  template   String?

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]

  @@index([userId])
}

model GoalMilestone {
  id        String    @id @default(cuid())
  goalId    String
  userId    String
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([userId])
}

model Habit {
  id            String    @id @default(cuid())
  userId        String
  name          String
  frequency     Frequency @default(DAILY)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  category      Category  @default(HEALTH)
  createdAt     DateTime  @default(now())

  // personalisation + stacking
  icon           String?
  color          String?
  reminderTime   String? // "HH:MM" local
  routineId      String?
  orderInRoutine Int?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries HabitEntry[]
  routine HabitRoutine? @relation(fields: [routineId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model HabitRoutine {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits Habit[]

  @@index([userId])
}

model HabitEntry {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  date      DateTime @db.Date
  completed Boolean  @default(true)
  notes     String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mood      Int      @default(3) // 1-5
  tags      String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  score     Int // 1-10
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PomodoroSession {
  id          String   @id @default(cuid())
  userId      String
  goalId      String? // denormalised link; no FK to keep it simple
  minutes     Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  key      String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Partnership {
  id             String        @id @default(cuid())
  requesterId    String
  addresseeEmail String
  addresseeId    String?
  status         PartnerStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  requester User @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeEmail])
  @@index([requesterId])
  @@index([addresseeId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  message   String
  read      Boolean   @default(false)
  type      NotifType @default(SYSTEM)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
